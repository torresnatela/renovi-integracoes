# --- Banco de dados ---
# Produção (Neon Postgres): connection string com pool (PgBouncer).
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
# Connection string SEM pool, usada apenas para rodar migrations (drizzle-kit).
DATABASE_URL_UNPOOLED="postgresql://user:password@host/dbname?sslmode=require"
#
# Desenvolvimento local com Docker (docker compose up db) — use estas no lugar:
# DATABASE_URL="postgresql://renovi:renovi@localhost:5432/renovi"
# DATABASE_URL_UNPOOLED="postgresql://renovi:renovi@localhost:5432/renovi"

# --- Cron / processamento da fila ---
# Intervalo entre cada tentativa de processar a fila (ms). Padrão 5s.
CRON_TICK_MS=5000
# Tempo máximo que o endpoint de cron roda em loop por invocação (ms). < maxDuration.
CRON_MAX_RUNTIME_MS=55000
# Quantos itens da fila processar por tick. Padrão 1 ("a próxima requisição").
CRON_BATCH_SIZE=1
